# 複製為 secrets.toml 後填入真實值（勿提交 secrets.toml）
# 本機：.streamlit/secrets.toml
# Streamlit Cloud：App settings → Secrets

ADMIN_PASSWORD = "請改成強密碼"

# 選用：Turso 雲端 SQLite（多人遠端必填）
# TURSO_DATABASE_URL = "libsql://your-db-name-org.turso.io"
# TURSO_AUTH_TOKEN = "eyJ..."

# 選用：本機或掛載磁碟的 SQLite 路徑（未設 Turso 時使用）
# DATABASE_PATH = "/path/to/etf_tracker.db"
